# ── BASIS environment ────────────────────────────────────────────────
# Copy to .env (worker) / .env.local (frontend). Never commit real keys.

# Supabase — project settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # worker + server API routes ONLY, never the browser
NEXT_PUBLIC_SUPABASE_URL=           # same URL, read by the frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # anon key (RLS read-only policies apply)

# Operator gate for logging paper trades from the UI
OPERATOR_TOKEN=

# Alerts — configure ONE channel (Telegram is simpler and fully free)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# …or Twilio WhatsApp sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=               # e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_TO=                 # e.g. whatsapp:+91XXXXXXXXXX

# Optional overrides
BASIS_PUBLIC_URL=https://basis.vercel.app
# BASIS_START_DATE=2019-01-01
